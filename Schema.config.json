        "hardness": {
          "type": "number",
          "description": "Mining time in seconds (seconds_to_destroy). Higher = takes longer to mine.",
          "default": 2.0,
          "minimum": 0,
          "examples": [0.3, 1.0, 2.0, 3.0, 3.5]
        },
        "resistance": {
          "type": "number",
          "description": "Explosion resistance. Higher = harder to blow up.",
          "default": 6.0,
          "minimum": 0,
          "examples": [0.3, 1.0, 3.0, 6.0]
        },
        "light_emission": {
          "type": "integer",
          "description": "Light level emitted by the block (0-15). Set to 15 for full brightness (glowstone, froglights, etc.).",
          "default": 0,
          "minimum": 0,
          "maximum": 15
        },
        "flammable": {
          "description": "Whether the block can catch fire and burn. Set to true for wood defaults (catch=5, destroy=20), or use an object for custom values.",
          "default": false,
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["catch_chance", "destroy_chance"],
              "properties": {
                "catch_chance": {
                  "type": "integer",
                  "description": "Chance modifier for catching fire from nearby flames. Vanilla wood = 5.",
                  "default": 5,
                  "minimum": 0
                },
                "destroy_chance": {
                  "type": "integer",
                  "description": "Chance modifier for being destroyed by fire. Vanilla wood = 20.",
                  "default": 20,
                  "minimum": 0
                }
              }
            }
          ]
        },
        "oxidizes": {
          "type": "boolean",
          "description": "Whether the block oxidizes over time (copper aging). Adds the copper_oxidation custom component. Only set true for unwaxed, non-fully-oxidized copper variants.",
          "default": false
        },
        "render_method": {
          "type": "string",
          "description": "Material render method for the block texture.\n• opaque — Fully solid, no transparency\n• alpha_test — Binary transparency (fully visible or invisible)\n• blend — Smooth semi-transparency\n• double_sided — Renders both face sides",
          "default": "alpha_test",
          "enum": ["opaque", "alpha_test", "blend", "double_sided"]
        },
        "uv": {
          "type": "object",
          "description": "Custom per-face UV mapping for horizontal slab geometry. Only used when type is horizontal_slab or slab_set. Each face defines origin and size within the 16×16 texture space. Defaults: sides show bottom half of texture, top/bottom show full texture. Omitted faces use defaults.",
          "additionalProperties": false,
          "properties": {
            "north": { "$ref": "#/$defs/face_uv" },
            "south": { "$ref": "#/$defs/face_uv" },
            "east":  { "$ref": "#/$defs/face_uv" },
            "west":  { "$ref": "#/$defs/face_uv" },
            "up":    { "$ref": "#/$defs/face_uv" },
            "down":  { "$ref": "#/$defs/face_uv" }
          }
        }
      }
