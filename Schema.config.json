{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/TheIco2/BedrockJSONSchema/master/Schema.config.json",
  "title": "Block Generator Configuration",
  "description": "Configuration file for the SlabsPlus Minecraft Bedrock addon generator. Defines all blocks to generate with their properties, textures, and behaviors. Run generate.ps1 (Windows) or generate.sh (Linux/Mac) after editing.",
  "type": "object",
  "required": ["namespace", "blocks"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for validation and autocomplete"
    },
    "namespace": {
      "type": "string",
      "description": "Addon namespace prefix for all generated block identifiers (e.g., 'mplus' produces 'mplus:vertical_slab_oak')",
      "default": "mplus",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "format_version": {
      "type": "string",
      "description": "Block format version for generated block JSON files. Must be 1.21.90+ for custom components.",
      "default": "1.21.90",
      "enum": ["1.21.90"]
    },
    "recipe_format_version": {
      "type": "string",
      "description": "Format version for generated recipe JSON files.",
      "default": "1.21.40",
      "enum": ["1.21.40", "1.21.50", "1.21.60"]
    },
    "blocks": {
      "type": "array",
      "description": "Array of block definitions. Each entry generates block JSON(s), recipe(s), texture entries, and language strings.",
      "items": {
        "$ref": "#/$defs/block_entry"
      }
    }
  },
  "$defs": {
    "block_entry": {
      "type": "object",
      "required": ["id", "type", "display_name", "source_block", "texture", "sound"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique block identifier suffix. Combined with namespace and type prefix to form the full block ID:\n• vertical_slab → '{namespace}:vertical_slab_{id}'\n• horizontal_slab → '{namespace}:horizontal_slab_{id}'\n• slab_set → both of the above",
          "pattern": "^[a-z][a-z0-9_]*$",
          "examples": ["oak", "cobblestone", "cut_copper", "ochre_froglight"]
        },
        "type": {
          "type": "string",
          "description": "Block generation type:\n• vertical_slab — One vertical slab. Recipes: source_block ↔ vertical (1:1 each way)\n• horizontal_slab — One horizontal slab. Recipe: 3 source_blocks → 6 slabs (shaped)\n• slab_set — Both horizontal + vertical. Recipes: 3 blocks → 6 horizontal + h↔v (1:1 each way)",
          "enum": ["block", "vertical_slab", "horizontal_slab", "slab_set", "pipe", "stair", "horizontal_stair", "wall", "fence", "fence_gate", "door", "trapdoor", "button", "pressure_plate", "sign", "hanging_sign", "bed", "chair", "table", "sofa", "shelf", "pillar", "window", "custom", "none"]
        },
        "display_name": {
          "type": "string",
          "description": "Base display name (without 'Vertical' prefix or 'Slab' suffix). The generator constructs full names:\n• vertical_slab → 'Vertical {name} Slab'\n• horizontal_slab → '{name} Slab'\n• slab_set → horizontal: '{name} Slab', vertical: 'Vertical {name} Slab'",
          "examples": ["Oak", "Cobblestone", "Cut Copper", "Ochre Froglight"]
        },
        "source_block": {
          "type": "string",
          "description": "Vanilla block identifier for crafting recipes:\n• For vertical_slab: the vanilla slab (e.g., 'minecraft:oak_slab')\n• For horizontal_slab/slab_set: the full block (e.g., 'minecraft:ochre_froglight')",
          "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_]*$",
          "examples": [
            "minecraft:oak_slab",
            "minecraft:spruce_slab",
            "minecraft:birch_slab",
            "minecraft:jungle_slab",
            "minecraft:acacia_slab",
            "minecraft:dark_oak_slab",
            "minecraft:mangrove_slab",
